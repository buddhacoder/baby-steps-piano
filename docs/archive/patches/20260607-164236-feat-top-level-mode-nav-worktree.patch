+/* ── Drawer Handle Tab ─────────────────────────────────────
+   A persistent musical tab on the left edge of the drawer
+   that's always reachable regardless of scroll position.
+   ───────────────────────────────────────────────────────── */
+.drawer-handle-tab {
+  position: fixed;
+  top: 50%;
+  /* When drawer is closed: flush against right edge of screen */
+  right: 0;
+  z-index: 1001;
+
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  gap: 3px;
+
+  width: 30px;
+  height: 76px;
+  padding: 0;
+  border: 1px solid rgba(50, 90, 160, 0.35);
+  border-right: none;
+  border-radius: 12px 0 0 12px;
+  overflow: hidden;
+
+  background: linear-gradient(180deg, #3d72d4 0%, #2856b0 100%);
+  box-shadow: -3px 2px 12px -2px rgba(10, 24, 46, 0.35),
+              0 0 8px rgba(61, 114, 212, 0.2);
+  cursor: pointer;
+  /* GPU-promote the layer so repaints don't cause sub-pixel jitter */
+  transform: translateY(-50%);
+  will-change: right;
+  backface-visibility: hidden;
+  -webkit-backface-visibility: hidden;
+  /* Only transition right (drawer slide) — no background/shadow transitions */
+  transition: right 220ms ease;
+  -webkit-tap-highlight-color: transparent;
+}
+
+/* Hover highlight uses an overlay so the button's geometry never changes */
+.drawer-handle-tab::after {
+  content: '';
+  position: absolute;
+  inset: 0;
+  border-radius: inherit;
+  background: rgba(255, 255, 255, 0.12);
+  opacity: 0;
+  transition: opacity 150ms ease;
+  pointer-events: none;
+}
+
+.drawer-handle-tab:hover::after {
+  opacity: 1;
+}
+
+.drawer-handle-tab:active::after {
+  background: rgba(0, 0, 0, 0.12);
+  opacity: 1;
+}
+
+/* When drawer is open: slide tab to sit at the drawer's left edge */
+.drawer-handle-tab.is-drawer-open {
+  right: min(560px, 94vw);
+}
